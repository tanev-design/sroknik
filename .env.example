# Supabase Configuration (optional — enables login + cloud sync)
PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Срокник Plus — license worker (Cloudflare Worker URL).
VITE_LICENSE_WORKER_URL="https://sroknik-license.YOUR_SUBDOMAIN.workers.dev"

# Stripe — subscription edition (€3/mo + €25/yr).
# Pricing table embed (preferred): create in Stripe Dashboard → Product Catalog → Pricing tables.
VITE_STRIPE_PRICING_TABLE_ID="prctbl_xxx"
VITE_STRIPE_PUBLISHABLE_KEY="pk_live_xxx"
# Customer portal direct link (Stripe Dashboard → Settings → Billing → Customer portal).
VITE_STRIPE_PORTAL_URL="https://billing.stripe.com/p/login/xxx"
# Price IDs, used to label the active plan as monthly vs yearly.
VITE_STRIPE_PRICE_MONTHLY="price_xxx"
VITE_STRIPE_PRICE_YEARLY="price_xxx"

# Legacy one-time payment link (kept only as fallback if pricing table is unset).
# VITE_STRIPE_PAYMENT_LINK="https://buy.stripe.com/YOUR_LINK_ID"
