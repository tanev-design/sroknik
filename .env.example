# Supabase Configuration (optional — enables login + cloud sync)
PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Срокник Plus — license worker + Stripe payment link.
# Both must be set in production before enabling /plus payments.
VITE_LICENSE_WORKER_URL="https://sroknik-license.YOUR_SUBDOMAIN.workers.dev"
VITE_STRIPE_PAYMENT_LINK="https://buy.stripe.com/YOUR_LINK_ID"
